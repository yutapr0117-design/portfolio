{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "includeGitInstructions": true,
  "env": {
    "MAX_THINKING_TOKENS": "31999"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit(**)",
      "Write(**)",
      "Edit(.claude/**/*.md)",
      "Write(.claude/**/*.md)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(brew *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(find*)",
      "Bash(diff*)",
      "Bash(sort*)",
      "Bash(uniq*)",
      "Bash(sha256sum*)",
      "Bash(mkdir*)",
      "Bash(mv*)",
      "Bash(cp*)",
      "Bash(touch*)",
      "Bash(echo*)"
    ],
    "ask": [
      "Edit(llms-full.txt)",
      "Write(llms-full.txt)",
      "Edit(llms.txt)",
      "Write(llms.txt)",
      "Edit(llms_well-known.txt)",
      "Write(llms_well-known.txt)",
      "Edit(.well-known/**)",
      "Write(.well-known/**)"
    ],
    "deny": [
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.json)",
      "Edit(.claude/settings.local.json)",
      "Write(.claude/settings.local.json)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Edit(*.webp)",
      "Write(*.webp)",
      "Edit(*.mp3)",
      "Write(*.mp3)",
      "Bash(git add .)",
      "Bash(git add -A*)",
      "Bash(git add --all*)",
      "Bash(git add :/*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git clean*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  }
}
